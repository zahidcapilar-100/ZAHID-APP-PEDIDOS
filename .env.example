# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# WEBHOOK OBTENIDO EN EL MÓDULO 1
VITE_WEBHOOK_URL="https://hook.us1.make.com/your-notion-webhook-id"

# SUPABASE CONFIGURATION (MÓDULO 2)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# NOTION OAUTH CONFIGURATION (MÓDULO 2)
VITE_NOTION_CLIENT_ID="1de2bf1e-b873-80b1-8408-0037a3ca9bf1"
VITE_NOTION_REDIRECT_URI="http://localhost:3000/admin/integraciones/callback"

# EDGE FUNCTION SECRETS (SUPABASE DASHBOARD -> SECRETS)
